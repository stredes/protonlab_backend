rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'root');
    }

    function isRoot() {
      return isAuthenticated() && getUserRole() == 'root';
    }

    // ── Products ─────────────────────────────────────────────────────────────
    // Lectura pública (catálogo visible para todos)
    // Escritura solo para admin y root
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Categories ───────────────────────────────────────────────────────────
    // Lectura pública
    // Escritura solo para admin y root
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Solo root puede leer y gestionar usuarios
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isRoot();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isRoot();
    }

    // ── Quotes (Cotizaciones) ─────────────────────────────────────────────────
    match /quotes/{quoteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────────
    match /audit/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Los logs son inmutables
    }

    // ── Bloques / Config ──────────────────────────────────────────────────────
    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if isRoot();
    }

    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}